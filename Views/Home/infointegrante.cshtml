@using Tp01.Models
@{
    ViewData["Title"] = "Detalle del Integrante";
    Integrante integrante = (Integrante)ViewBag.Integrante;
}

<link rel="stylesheet" href="~/css/site.css" />

@if (integrante != null)
{
    <div class="detalle">
        <div class="detalle-header">
            <img src="@integrante.Foto" class="fotoGrande" />
            <h1>@integrante.Nombre</h1>
        </div>

        <div class="detalle-body">

            <div class="clase1">
                <h3>datos </h3>
                <p><strong>DNI:</strong> @integrante.DNI</p>
                <p><strong>Fecha de nacimiento:</strong> @integrante.FechaNacimiento.ToShortDateString()</p>
            </div>

            <div class="clase1">
                <h3> familias</h3>
                <ul>
                    @foreach (var f in integrante.Familiares)
                    {
                        <li>@f</li>
                    }
                </ul>
            </div>

            <div class="clase1">
                <h3>intereses</h3>
                <ul>
                    @foreach (var i in integrante.Intereses)
                    {
                        <li>@i</li>
                    }
                </ul>
            </div>

        </div>

        <a class="clasevolver" href='@Url.Action("Index", "Home")'>⬅ Volver al grupo</a>
    </div>
}